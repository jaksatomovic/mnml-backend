{
  "mode_id": "QUESTION",
  "display_name": "Dnevno pitanje",
  "icon": "question",
  "cacheable": true,
  "description": "Otvoreno pitanje koje će potaknuti duboko razmišljanje",
  "content": {
    "type": "llm_json",
    "prompt_template": "Vi ste promišljeni filozof i savjetnik. Napravite otvoreno pitanje koje poziva na duboko razmišljanje, prikladno za 3-minutnu stanku za razmišljanje.\nIzlazni JSON:\n{{\"question\": \"The question (under 60 chars, concise and powerful)\", \"context_note\": \"Why this question matters (under 50 chars)\", \"category\": \"Category (Self / Relationships / Work / Life / Creativity)\"}}\nZahtjevi:\n1. Duboko, ali ne i teško; potiču na razmišljanje, ali ne i tjeskobu\n2. Otvoreno, ne da/ne\n3. Suptilno povezano s trenutnom sezonom/vremenskim prilikama/vrijemenom\n4. Sav tekst mora biti na engleskom jeziku\nIspis samo JSON.\nKontekst: {context}",
    "output_schema": {
      "question": {
        "type": "string",
        "default": "Što biste radili danas da vas nitko ne gleda?"
      },
      "context_note": {
        "type": "string",
        "default": "Autentičnost počinje iskrenim samorefleksijom"
      },
      "category": {
        "type": "string",
        "default": "sebe"
      }
    },
    "temperature": 0.9,
    "fallback": {
      "question": "Što biste radili danas da vas nitko ne gleda?",
      "context_note": "Autentičnost počinje iskrenim samorefleksijom",
      "category": "sebe"
    }
  },
  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": true
    },
    "layout_engine": "component_tree",
    "body_preset": "prompt_card",
    "preset_props": {
      "padding_x": 18,
      "padding_y": 10,
      "justify": "center",
      "gap": 8,
      "meta_template": "{category}",
      "meta_font_size": 10,
      "separator_width": 60,
