  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body_align": "top",
    "body": [
      {
        "type": "spacer",
        "height": 6
      },
      {
        "type": "text",
        "field": "city",
        "font": "lora_regular",
        "font_size": 16,
        "align": "left",
        "margin_x": 16,
        "max_lines": 1
      },
      {
        "type": "spacer",
        "height": 8
      },
      {
        "type": "two_column",
        "left_width": 168,
        "gap": 8,
        "left_x": 12,
        "left": [
          {
            "type": "big_number",
            "field": "today_temp",
            "font_size": 50,
            "align": "left",
            "margin_x": -4,
            "unit": "°C"
          },
          {
            "type": "spacer",
            "height": 2
          },
          {
            "type": "weather_icon_text",
            "code_field": "today_code",
            "field": "today_desc",
            "font": "lora_regular",
            "font_size": 15,
            "icon_size": 22,
            "align": "left",
            "margin_x": -4
          },
          {
            "type": "spacer",
            "height": 4
          },
          {
            "type": "text",
            "field": "today_range",
            "font": "lora_regular",
            "font_size": 13,
            "align": "left",
            "margin_x": -4,
            "max_lines": 1
          }
        ],
        "right": [
          {
            "type": "forecast_cards",
            "field": "forecast",
            "max_items": 4,
            "margin_x": -6,
            "gap": 4,
            "icon_size": 30
          }
        ]
      },
      {
        "type": "spacer",
        "height": 6
      },
      {
        "type": "icon_text",
        "icon": "humidity",
        "text": "Vlažnost {today_humidity}%   {today_wind_dir} {today_wind_level}",
        "font": "lora_regular",
        "font_size": 12,
        "align": "left",
        "margin_x": 12
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "icon_text",
        "icon": "sunrise",
        "text": "Izlazak sunca {sunrise}   Zalazak sunca {sunset}",
        "font": "lora_regular",
        "font_size": 12,
        "align": "left",
        "margin_x": 12
      },
      {
        "type": "spacer",
        "height": 8
      },
      {
        "type": "separator",
        "style": "solid",
        "line_width": 1,
        "margin_x": 16
      },
      {
        "type": "spacer",
        "height": 6
      },
      {
        "type": "text",
        "field": "advice",
        "font": "lora_regular",
        "font_size": 12,
        "align": "center",
        "margin_x": 14,
        "max_lines": 2
      }
    ],
    "footer": {
      "label": "Vrijeme",
      "attribution_template": "— Open-Meteo"
    }
  },
