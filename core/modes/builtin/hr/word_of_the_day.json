{
  "mode_id": "WORD_OF_THE_DAY",
  "display_name": "Riječ dana",
  "icon": "word",
  "cacheable": true,
  "description": "Zanimljiva engleska riječ s definicijom i primjerom",
  "content": {
    "type": "llm_json",
    "prompt_template": "Vi ste stručnjak za jezik. Odaberite zanimljivu, neuobičajenu, ali korisnu englesku riječ i navedite njezinu definiciju i upotrebu.\nIzlazni JSON: {{\"word\": \"The word\", \"phonetic\": \"Phonetic transcription (optional)\", \"definition\": \"Brief definition (under 30 chars)\", \"example\": \"Short example sentence (under 40 chars)\"}}\nOdaberite riječi koje su elegantne, korisne u svakodnevnom životu ili imaju zanimljivu etimologiju.\nKontekst: {context}",
    "output_schema": {
      "word": {
        "type": "string",
        "default": "Serendipity"
      },
      "phonetic": {
        "type": "string",
        "default": "/ˌsɛrənˈdɪpɪti/"
      },
      "definition": {
        "type": "string",
        "default": "Sretna nesreća ili ugodno iznenađenje"
      },
      "example": {
        "type": "string",
        "default": "Pronalazak te knjige bila je čista slučajnost."
      }
    },
    "temperature": 0.8,
    "fallback": {
      "word": "Serendipity",
      "phonetic": "/ˌsɛrənˈdɪpɪti/",
      "definition": "Sretna nesreća ili ugodno iznenađenje",
      "example": "Pronalazak te knjige bila je čista slučajnost."
    },
    "fallback_pool": [
      {
        "word": "Serendipity",
