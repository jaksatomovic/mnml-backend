{
  "mode_id": "RIDDLE",
  "display_name": "Dnevna zagonetka",
  "icon": "tips",
  "cacheable": true,
  "description": "Zabavna zagonetka, mozgalica ili trivijalno pitanje",
  "content": {
    "type": "llm_json",
    "prompt_template": "Ti si majstor zagonetki. Na temelju informacija o okruženju stvorite zabavnu zagonetku (zagonetku, mozgalicu ili trivijalnost — odaberite jednu).\nIzlazni JSON:\n{{\"category\": \"Type (Riddle / Brain Teaser / Trivia)\", \"question\": \"The question (under 80 chars)\", \"hint\": \"A hint (under 30 chars)\", \"answer\": \"The answer (under 30 chars)\"}}\nZahtjevi: zabavno, srednje teško, pogodno za sve uzraste. Ispis samo JSON.\nKontekst: {context}",
    "output_schema": {
      "category": {
        "type": "string",
        "default": "Zagonetka"
      },
      "question": {
        "type": "string",
        "default": "Imam gradove, ali ne i kuće. Imam planine, ali nemam drveća. Što sam ja?"
      },
      "hint": {
        "type": "string",
        "default": "Koristiš me da pronađeš mjesta."
      },
      "answer": {
        "type": "string",
        "default": "Karta"
      }
    },
    "temperature": 0.9,
    "fallback": {
      "category": "Zagonetka",
      "question": "Imam gradove, ali ne i kuće. Imam planine, ali nemam drveća. Što sam ja?",
      "hint": "Koristiš me da pronađeš mjesta.",
      "answer": "Karta"
    }
  },
  "layout": {
    "layout_engine": "component_tree",
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body_preset": "riddle_card",
    "preset_props": {
      "top_gap": 10,
      "meta_field": "category",
      "meta_font": "noto_serif_light",
      "meta_font_size": 11,
      "separator_width": 60,
      "question_inset_x": 26,
      "question_field": "question",
      "question_font": "noto_serif_bold",
      "question_font_size": 18,
      "question_max_lines": 4,
      "hint_field": "hint",
      "hint_template": "Savjet: {hint}",
      "hint_font": "noto_serif_light",
      "hint_font_size": 11,
      "hint_max_lines": 2,
      "answer_divider_margin_x": 60,
      "answer_field": "answer",
      "answer_font": "noto_serif_regular",
      "answer_font_size": 12
    },
    "footer": {
      "label": "Zagonetka",
      "attribution_template": "— Razmislite o tome"
    }
  },
