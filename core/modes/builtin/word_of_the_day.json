      },
      "example": {
        "type": "string",
        "default": "Traveling is full of serendipity."
      }
    },
    "temperature": 0.8,
    "fallback": {
      "word": "Serendipity",
      "phonetic": "/ˌser.ənˈdɪp.ə.ti/",
      "definition": "translated",
      "example": "Traveling is full of serendipity."
    }
  },
