{
  "mode_id": "MEMO",
  "display_name": "便签留言",
  "icon": "memo",
  "cacheable": false,
  "description": "在墨水屏上显示自定义留言",
  "settings_schema": [
    {
      "key": "memo_text",
      "label": "便签文本",
      "type": "textarea",
      "placeholder": "输入该模式单独使用的便签内容"
    }
  ],
  "content": {
    "type": "computed",
    "provider": "memo",
    "fallback": {
      "memo_text": "在配置页面设置你的便签内容"
    },
    "fallback_pool": [
      {
        "memo_text": "在配置页面设置你的便签内容"
      },
      {
        "memo_text": "今天也要元气满满"
      },
      {
        "memo_text": "专注当下，做好眼前事"
      },
      {
        "memo_text": "记得多喝水"
      },
      {
        "memo_text": "休息一下，眺望远方"
      }
    ]
  },
  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "layout_engine": "component_tree",
    "body_preset": "quote_focus_card",
    "preset_props": {
      "padding_x": 18,
      "justify": "center",
      "quote_inset_x": 30,
      "quote_field": "memo_text",
      "quote_font": "noto_serif_light",
      "quote_font_size": 16,
      "quote_max_lines": 4
    },
    "footer": {
      "label": "MEMO"
    }
  },
  "layout_overrides": {
