{
  "mode_id": "RIDDLE",
  "display_name": "每日一谜",
  "icon": "tips",
  "cacheable": true,
  "description": "谜语、脑筋急转弯、趣味知识题",
  "content": {
    "type": "llm_json",
    "prompt_template": "你是一位谜语大师。根据环境信息，出一道有趣的谜题（可以是谜语、脑筋急转弯、冷知识问答三选一）。\n用 JSON 输出：\n{{\"category\": \"类型（谜语/脑筋急转弯/冷知识）\", \"question\": \"谜面或问题（40字以内）\", \"hint\": \"提示（10字以内）\", \"answer\": \"谜底或答案（15字以内）\"}}\n要求：有趣，有意思，难度适中，老少皆宜。只输出 JSON。\n环境：{context}",
    "output_schema": {
      "category": {
        "type": "string",
        "default": "谜语"
      },
      "question": {
        "type": "string",
        "default": "两个胖子（打一城市名）"
      },
      "hint": {
        "type": "string",
        "default": "想想体重"
      },
      "answer": {
        "type": "string",
        "default": "合肥"
      }
    },
    "temperature": 0.9,
    "fallback": {
      "category": "谜语",
      "question": "两个胖子（打一城市名）",
      "hint": "想想体重",
      "answer": "合肥"
    }
  },
  "layout": {
    "layout_engine": "component_tree",
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body_preset": "riddle_card",
    "preset_props": {
      "top_gap": 10,
      "meta_field": "category",
      "meta_font": "noto_serif_light",
      "meta_font_size": 11,
      "separator_width": 60,
      "question_inset_x": 26,
      "question_field": "question",
      "question_font": "noto_serif_bold",
      "question_font_size": 18,
      "question_max_lines": 4,
      "hint_field": "hint",
      "hint_template": "Hint: {hint}",
      "hint_font": "noto_serif_light",
      "hint_font_size": 11,
      "hint_max_lines": 2,
      "answer_divider_margin_x": 60,
      "answer_field": "answer",
      "answer_font": "noto_serif_regular",
      "answer_font_size": 12
    },
    "footer": {
      "label": "Riddle",
      "attribution_template": "— Think About It"
    }
  },
