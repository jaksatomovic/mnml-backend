{
  "mode_id": "ALMANAC",
  "display_name": "translated",
  "icon": "calendar",
  "cacheable": false,
  "description": "translated、translated、translated、translated",
  "content": {
    "type": "composite",
    "steps": [
      {
        "type": "computed",
        "provider": "daily_meta",
        "fallback": {
          "year": 2026,
          "day": 1,
          "month_cn": "January",
          "weekday_cn": "Mon",
          "day_of_year": 1,
          "days_in_year": 365
        }
      },
      {
        "type": "llm_json",
        "prompt_template": "translated。Get by translated，translated。\ntranslated JSON translated：\n{{\"lunar_date\": \"translated（translated：translated）\", \"solar_term\": \"translated（translated：Major Cold）\", \"yi\": \"translated（3translated，translated，translated：translated、translated、translated）\", \"ji\": \"translated（2translated，translated，translated：translated、translated）\", \"direction\": \"translated（translated：translated）\", \"health_tip\": \"translated（15translated）\"}}\ntranslated JSON。\ntranslated：{context}",
        "output_schema": {
          "lunar_date": {
            "type": "string",
            "default": "translated"
          },
          "solar_term": {
            "type": "string",
            "default": "Start of Spring"
          },
          "yi": {
            "type": "string",
            "default": "translated、translated、translated"
          },
          "ji": {
            "type": "string",
            "default": "translated、translated"
          },
          "direction": {
            "type": "string",
            "default": "translated"
          },
          "health_tip": {
            "type": "string",
            "default": "translated，translated"
          }
        },
        "temperature": 0.6,
        "fallback": {
          "lunar_date": "translated",
          "solar_term": "Start of Spring",
          "yi": "translated、translated、translated",
          "ji": "translated、translated",
          "direction": "translated",
          "health_tip": "translated，translated"
        }
      }
    ],
    "fallback": {}
  },
  "layout": {
    "status_bar": {
      "line_width": 2,
      "dashed": false
    },
    "body": [
      {
        "type": "two_column",
        "left_width": 120,
        "gap": 10,
        "left": [
          {
            "type": "text",
            "field": "lunar_date",
            "font_size": 12,
            "align": "center",
            "margin_x": 8
          },
          {
            "type": "big_number",
            "field": "day",
            "font_size": 48,
            "align": "center"
          },
          {
            "type": "text",
            "field": "month_cn",
            "font_size": 14,
            "align": "center",
            "margin_x": 8
          },
          {
            "type": "text",
            "field": "weekday_cn",
            "font_size": 12,
            "align": "center",
            "margin_x": 8
          },
          {
            "type": "separator",
            "style": "short",
            "width": 50
          },
          {
            "type": "text",
            "field": "solar_term",
            "font": "noto_serif_bold",
            "font_size": 16,
            "align": "center",
            "margin_x": 8
          }
        ],
        "right": [
          {
            "type": "spacer",
            "height": 4
          },
          {
            "type": "group",
            "title": "translated",
            "title_font_size": 14,
            "margin_x": 8,
            "children": [
              {
                "type": "text",
                "field": "yi",
                "font_size": 13,
                "align": "left",
                "margin_x": 8,
                "max_lines": 2
              }
            ]
          },
          {
            "type": "spacer",
            "height": 6
          },
          {
            "type": "group",
            "title": "translated",
            "title_font_size": 14,
            "margin_x": 8,
            "children": [
              {
                "type": "text",
                "field": "ji",
                "font_size": 13,
                "align": "left",
                "margin_x": 8,
                "max_lines": 2
              }
            ]
          },
          {
            "type": "spacer",
            "height": 4
          },
          {
            "type": "separator",
            "style": "dashed",
            "margin_x": 8
          },
          {
            "type": "spacer",
            "height": 4
          },
          {
            "type": "text",
            "template": "translated {direction}",
            "font_size": 12,
            "align": "left",
            "margin_x": 8
          },
          {
            "type": "text",
            "field": "health_tip",
            "font": "noto_serif_light",
            "font_size": 11,
            "align": "left",
            "margin_x": 8,
            "max_lines": 2
          }
        ]
      }
    ],
    "footer": {
      "label": "???",
      "attribution_template": "— {solar_term}",
      "line_width": 2
    }
  },
