{
  "mode_id": "MEMO",
  "display_name": "Memo",
  "icon": "memo",
  "cacheable": false,
  "description": "Display your custom message on the screen",
  "settings_schema": [
    {
      "key": "memo_text",
      "label": "Memo text",
      "type": "textarea",
      "placeholder": "Enter your memo content for this mode"
    }
  ],
  "content": {
    "type": "computed",
    "provider": "memo",
    "fallback": {"memo_text": "Set your memo in the config page."},
    "fallback_pool": [
      {"memo_text": "Set your memo in the config page."},
      {"memo_text": "Stay positive and keep going!"},
      {"memo_text": "Focus on the present moment."},
      {"memo_text": "Remember to stay hydrated."},
      {"memo_text": "Take a break and look into the distance."}
    ]
  },
  "layout": {
    "status_bar": {"line_width": 1, "dashed": false},
    "layout_engine": "component_tree",
    "body_preset": "quote_focus_card",
    "preset_props": {
      "padding_x": 18,
      "justify": "center",
      "quote_inset_x": 30,
      "quote_field": "memo_text",
      "quote_font": "noto_serif_light",
      "quote_font_size": 16,
      "quote_max_lines": 4
    },
    "footer": {"label": "MEMO"}
  },
  "layout_overrides": {
    "296x128": {
      "preset_props": {
        "padding_x": 8,
        "quote_inset_x": 8,
        "quote_font_size": 13,
        "quote_max_lines": 3
      },
      "footer": {"label": "MEMO", "height": 18}
    },
    "800x480": {
      "preset_props": {
        "padding_x": 28,
        "quote_inset_x": 72,
        "quote_font_size": 26,
        "quote_max_lines": 4
      }
    }
  }
}
