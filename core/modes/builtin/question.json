{
  "mode_id": "QUESTION",
  "display_name": "translated",
  "icon": "question",
  "cacheable": true,
  "description": "translated",
  "content": {
    "type": "llm_json",
    "prompt_template": "translated。translated，translated3translated。\ntranslated JSON translated：\n{{\"question\": \"translated（30translated，translated）\", \"context_note\": \"translated（25translated）\", \"category\": \"translated（translated/translated/translated/translated/translated）\"}}\ntranslated：\n1. translated，translated\n2. translated/translated，translated\n3. translated、weather、translated\ntranslated JSON。\ntranslated：{context}",
