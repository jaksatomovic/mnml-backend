{
  "mode_id": "HALO_F1_NEWS",
  "display_name": "Halo F1 News",
  "icon": "global",
  "cacheable": false,
  "description": "Latest Formula 1 headlines inspired by Halo F1.",
  "settings_schema": [
    {
      "key": "item_limit",
      "label": "Headlines",
      "type": "number",
      "default": 5,
      "min": 3,
      "max": 8,
      "step": 1,
      "description": "How many F1 headlines to fetch from the RSS feed."
    }
  ],
  "content": {
    "type": "external_data",
    "provider": "halo_f1_news",
    "fallback": {
      "lead_title": "No F1 headlines available",
      "lead_desc": "Try again in a few minutes.",
      "lead_pub_date": "",
      "news_items": [
        {
          "short_title": "Feed unavailable"
        }
      ]
    }
  },
  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body": [
      {
        "type": "text",
        "text": "F1 News",
        "font_size": 16,
        "align": "center",
        "max_lines": 1,
        "margin_x": 14
      },
      {
        "type": "text",
        "text": "Latest paddock headlines",
        "font_size": 9,
        "align": "center",
        "max_lines": 1,
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 3
      },
      {
        "type": "separator",
        "style": "solid",
        "line_width": 1,
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 6
      },
      {
        "type": "text",
        "field": "lead_title",
        "font_size": 14,
        "align": "left",
        "margin_x": 14,
        "max_lines": 2
      },
      {
        "type": "spacer",
        "height": 3
      },
      {
        "type": "text",
        "field": "lead_desc",
        "font_size": 10,
        "align": "left",
        "margin_x": 14,
        "max_lines": 3
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "text",
        "field": "lead_pub_date",
        "font_size": 9,
        "align": "right",
        "margin_x": 14,
        "max_lines": 1
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "separator",
        "style": "dashed",
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "group",
        "title": "More Headlines",
        "title_font_size": 11,
        "margin_x": 14,
        "children": [
          {
            "type": "list",
            "field": "news_items",
            "item_template": "{short_title}",
            "font_size": 10,
            "item_spacing": 12,
            "margin_x": 14,
            "max_items": 7
          }
        ]
      }
    ],
    "footer": {
      "label": "F1 NEWS",
      "attribution_template": "— The Race"
    }
  },
