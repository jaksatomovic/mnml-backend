{
  "mode_id": "HALO_F1_RESULTS",
  "display_name": "Halo F1 Results",
  "icon": "trophy",
  "cacheable": false,
  "description": "Latest Formula 1 session results inspired by Halo F1.",
  "settings_schema": [
    {
      "key": "item_limit",
      "label": "Rows",
      "type": "number",
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 1,
      "description": "How many result rows to fetch from the latest completed session."
    }
  ],
  "content": {
    "type": "external_data",
    "provider": "halo_f1_results",
    "fallback": {
      "session_label": "Latest Results",
      "leader_name": "No results yet",
      "leader_detail": "",
      "result_rows_left": [
        {
          "line": "1. Results unavailable"
        }
      ],
      "result_rows_right": [],
      "result_rows": [
        {
          "line": "1. Results unavailable"
        }
      ]
    }
  },
  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body": [
      {
        "type": "text",
        "field": "session_label",
        "font_size": 16,
        "align": "center",
        "max_lines": 1,
        "margin_x": 14
      },
      {
        "type": "text",
        "text": "Latest classification snapshot",
        "font_size": 9,
        "align": "center",
        "max_lines": 1,
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 3
      },
      {
        "type": "separator",
        "style": "solid",
        "line_width": 1,
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 6
      },
      {
        "type": "group",
        "title": "Winner",
        "title_font_size": 11,
        "margin_x": 14,
        "children": [
          {
            "type": "two_column",
            "left_x": 14,
            "left_width": 176,
            "gap": 8,
            "right_margin": 14,
            "left": [
              {
                "type": "text",
                "field": "leader_name",
                "font_size": 15,
                "align": "left",
                "margin_x": 0,
                "max_lines": 1
              }
            ],
            "right": [
              {
                "type": "text",
                "field": "leader_detail",
                "font_size": 11,
                "align": "right",
                "margin_x": 0,
                "max_lines": 1
              }
            ]
          }
        ]
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "separator",
        "style": "dashed",
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "group",
        "title": "Classification",
        "title_font_size": 11,
        "margin_x": 14,
        "children": [
          {
            "type": "two_column",
            "left_x": 14,
            "left_width": 176,
            "gap": 8,
            "right_margin": 14,
            "left": [
              {
                "type": "list",
                "field": "result_rows_left",
                "item_template": "{line}",
                "font_size": 9,
                "item_spacing": 10,
                "margin_x": 0,
                "max_items": 10
              }
            ],
            "right": [
              {
                "type": "list",
                "field": "result_rows_right",
                "item_template": "{line}",
                "font_size": 9,
                "item_spacing": 10,
                "margin_x": 0,
                "max_items": 10
              }
            ]
          }
        ]
      }
    ],
    "footer": {
      "label": "F1 RESULTS",
      "attribution_template": "— OpenF1"
    }
  }
}
