{
  "mode_id": "HALO_F1_WEEKEND",
  "display_name": "Halo F1 Weekend",
  "icon": "calendar",
  "cacheable": false,
  "description": "Upcoming Formula 1 weekend schedule with track weather.",
  "content": {
    "type": "external_data",
    "provider": "halo_f1_weekend",
    "fallback": {
      "race_name": "Formula 1 Weekend",
      "circuit_name": "",
      "country": "",
      "next_session_label": "",
      "next_session_time": "",
      "weekend_rows": [
        {
          "line": "Schedule unavailable"
        }
      ]
    }
  },
  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body": [
      {
        "type": "text",
        "field": "race_name",
        "font_size": 16,
        "align": "center",
        "max_lines": 1,
        "margin_x": 14
      },
      {
        "type": "text",
        "text": "Weekend timetable",
        "font_size": 9,
        "align": "center",
        "max_lines": 1,
        "margin_x": 14
      },
      {
        "type": "text",
        "text": "{circuit_name} · {country}",
        "font_size": 9,
        "align": "center",
        "max_lines": 1,
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "separator",
        "style": "solid",
        "line_width": 1,
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 6
      },
      {
        "type": "group",
        "title": "Next Up",
        "title_font_size": 11,
        "margin_x": 14,
        "children": [
          {
            "type": "two_column",
            "left_x": 14,
            "left_width": 176,
            "gap": 8,
            "right_margin": 14,
            "left": [
              {
                "type": "text",
                "field": "next_session_label",
                "font_size": 14,
                "align": "left",
                "margin_x": 0,
                "max_lines": 1
              }
            ],
            "right": [
              {
                "type": "text",
                "field": "next_session_time",
                "font_size": 14,
                "align": "right",
                "margin_x": 0,
                "max_lines": 1
              }
            ]
          }
        ]
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "separator",
        "style": "dashed",
        "margin_x": 14
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "group",
        "title": "Weekend Schedule",
        "title_font_size": 11,
        "margin_x": 14,
        "children": [
          {
            "type": "list",
            "field": "weekend_rows",
            "item_template": "{line}",
            "font_size": 9,
            "item_spacing": 11,
            "margin_x": 14,
            "max_items": 8
          }
        ]
      }
    ],
    "footer": {
      "label": "F1 WEEKEND",
      "attribution_template": "— Jolpica · Meteo"
    }
  }
}
