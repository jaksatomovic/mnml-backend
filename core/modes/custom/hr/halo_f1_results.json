{
  "mode_id": "HALO_F1_RESULTS",
  "display_name": "Halo F1 rezultati",
  "icon": "trophy",
  "cacheable": false,
  "description": "Najnoviji rezultati Formule 1 nadahnuti Halo F1.",
  "settings_schema": [
    {
      "key": "item_limit",
      "label": "Redovi",
      "type": "number",
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 1,
      "description": "Koliko redaka rezultata za dohvaćanje iz zadnje dovršene sesije."
    }
  ],
  "content": {
    "type": "external_data",
    "provider": "halo_f1_results",
    "fallback": {
      "session_label": "Najnoviji rezultati",
      "leader_name": "Još nema rezultata",
      "leader_detail": "",
      "result_rows_left": [
        {
          "line": "1. Rezultati nedostupni"
        }
      ],
      "result_rows_right": [],
      "result_rows": [
        {
          "line": "1. Rezultati nedostupni"
        }
      ]
    }
  },
  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body": [
