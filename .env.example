# InkSight Backend Environment Variables

# ============================================
# LLM API Keys
# ============================================
# Request and fill in the API key below yourself.

# Deepseek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Application Settings
# ============================================

# Debug mode (set to 1 to enable verbose logging)
DEBUG_MODE=0

# Allow LAN IP Host/Origin headers in local development.
# Recommended when testing devices against a Mac/PC on your home network.
INKSIGHT_CORS_ALLOW_LAN=1

# Default city for weather (if device config not set)
DEFAULT_CITY=Zagreb

# Neon / Postgres connection string (required)
DATABASE_URL=

# Disk cache for user-uploaded images (for example MY_ADAPTIVE): `backend/runtime_uploads/`
# Cleanup uses last access time: every successful `GET /api/uploads/{id}` updates mtime,
# so files still being referenced by devices are not removed accidentally.
# Set to 0 to disable age-based cleanup.
INKSIGHT_UPLOADS_MAX_AGE_DAYS=30
# Combined size limit for all `.bin` files in MB. If exceeded, the oldest least-recently-used files are removed.
# Set to 0 to disable the total-size limit.
INKSIGHT_UPLOADS_MAX_TOTAL_MB=512

INKSIGHT_FONT_ENGINE=bitmap

# Public backend base URL used when generating absolute URLs for runtime images
# (for example OpenAI image generation in ARTWALL mode).
INKSIGHT_BACKEND_PUBLIC_BASE=http://127.0.0.1:8080

# ============================================
# Plugin Security (Discover / Plugin system)
# ============================================
# Require plugin signature verification on install (0/1).
INKSIGHT_PLUGIN_REQUIRE_SIGNATURE=0
# HMAC secret used to verify plugin signatures.
# Signature payload format: plugin_id|version|canonical_mode_json
INKSIGHT_PLUGIN_SIGNING_SECRET=

# ============================================
# Email SMTP (password reset codes, email verification)
# ============================================
# If not configured, verification codes are only printed to the server log in development.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SSL=1

# ============================================
# Auth Configuration
# ============================================

# Access key for admin endpoints (config management, mode management, stats overview, and similar routes).
# Leave empty to reject all admin requests.
ADMIN_TOKEN=
